model User {
  userId    String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  status    Status   @default(TRIAL)
  updatedAt DateTime @updatedAt
  createAt  DateTime @default(now())

  googleAuth        Boolean   @default(false)
  language          String?
  profileImage      String?
  operationsRole    String?
  otp               Int?
  isVerified        Boolean   @default(false)
  refreshToken      String?
  resetToken        String?
  resetTokenExpires DateTime?

  phone   String?
  address String?
  country String?

  @@index([operationsRole])
  @@index([name])
  @@index([googleAuth])
}
