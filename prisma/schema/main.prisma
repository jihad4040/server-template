generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  BUYER
  SELLER
  DEALER
  ADMIN
  SUPER_ADMIN
}

enum Status {
  ACTIVE
  TRIAL
  SUSPEND
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}
